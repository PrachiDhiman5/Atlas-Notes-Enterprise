# --- Dependencies ---
node_modules/

# --- Environment & secrets (never commit real values) ---
.env
.env.*
!.env.example
!.env.*.example

# --- Build output ---
dist/
build/

# --- Logs & diagnostics ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Test & coverage ---
coverage/
.nyc_output/

# --- Uploads (keep empty dir with .gitkeep only) ---
server/storage/uploads/*
!server/storage/uploads/.gitkeep

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini

# --- IDE / editor ---
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- Misc ---
*.pem
.cache/
