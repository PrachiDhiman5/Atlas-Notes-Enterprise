# Local dev (recommended): leave both unset — Vite proxies /api and /socket.io to http://localhost:5000
# VITE_API_URL=
# VITE_SOCKET_URL=

# If the API runs on another host/port during dev:
# VITE_DEV_API_PROXY=http://localhost:4000

# Production / custom API: full URLs (no Vite proxy)
# VITE_API_URL=https://your-api.onrender.com/api/v1
# VITE_SOCKET_URL=https://your-api.onrender.com
