NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/collab_notes
# CORS: comma-separated origins (defaults include localhost + 127.0.0.1 on 5173/5174)
CLIENT_URL=http://localhost:5173
JWT_ACCESS_SECRET=replace_with_access_secret
JWT_REFRESH_SECRET=replace_with_refresh_secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
# Link inside verification email (use your real app URL in production)
APP_BASE_URL=http://localhost:5173
#
# --- Email (verification / password reset) ---
# Signup emails always go TO the address the user typed. SMTP_* is only YOUR
# “send mail as” account (login for the mail server), not the recipient.
#
# Gmail example:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_no_spaces
SMTP_FROM=your_email@gmail.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Local files when Cloudinary is unset (default: server/storage/uploads)
# UPLOAD_DIR=
